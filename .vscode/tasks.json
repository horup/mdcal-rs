{
	"version": "2.0.0",
	"inputs": [
		{
			"id": "icalUrl",
			"type": "promptString",
			"description": "Enter ical Url",
			"password": false
		}
	],
	"tasks": [
		{
			"type": "cargo",
			"command": "run",
			"args": [
				"${input:icalUrl}",
				"month3",
				"--lang",
				"da",
				"--format",
				"html",
				"--file",
				"output.html"
			],
			"problemMatcher": [
				"$rustc"
			],
			"label": "mdcal month3"
		},
		{
			"type": "cargo",
			"command": "run",
			"args": [
				"help"
			],
			"problemMatcher": [
				"$rustc"
			],
			"label": "mdcal help"
		},
		{
			"type": "cargo",
			"command": "run",
			"args": [
				"${input:icalUrl}",
				"year",
				"--lang",
				"en"
			],
			"problemMatcher": [
				"$rustc"
			],
			"label": "mdcal year"
		},
		{
			"type": "cargo",
			"command": "publish",
			"problemMatcher": [
				"$rustc"
			],
			"label": "publish"
		},
	]
}